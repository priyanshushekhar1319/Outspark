FROM node:20-alpine

WORKDIR /app

COPY package*.json ./
RUN npm install

COPY . .

RUN npm run build

EXPOSE 3000

CMD ["npm", "start"]
```

Then go to Railway → **Frontend service → Settings:**

- **Dockerfile Path:** `Dockerfile.frontend`
- **Root Directory:** `frontend`
- **Start Command:** leave empty (Dockerfile handles it)

Also critically — go to **Variables** and make sure this exists:
```
NEXT_PUBLIC_API_URL = https://outspark-backend-production-ee3c.up.railway.app
